    {
      "parameters": {
        "jsCode": "// Busca o output diretamente no nó do agente (evita perda ao passar por nós intermediários)\nconst output = $('AI Agent Canvas').first().json.output;\n\nif (!output) {\n  throw new Error('Campo output não encontrado no AI Agent Canvas.');\n}\n\nconst marker = 'CANVAS_PRONTO\\n';\nconst idx = output.indexOf(marker);\n\nif (idx === -1) {\n  throw new Error('Marcador CANVAS_PRONTO não encontrado. Saída recebida: ' + output.substring(0, 200));\n}\n\nconst jsonStr = output.substring(idx + marker.length).trim();\n\nlet canvasData;\ntry {\n  canvasData = JSON.parse(jsonStr);\n} catch (e) {\n  throw new Error('Falha ao parsear JSON do canvas: ' + e.message + '\\nJSON recebido: ' + jsonStr.substring(0, 300));\n}\n\nreturn { json: canvasData };"
      },
